# Backend runtime
SECRET_KEY=civil-demo-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALLOWED_ORIGINS=*

# Preferred database connection
# 方式一：直接使用 DATABASE_URL
DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/kaogong_ai?charset=utf8mb4

# Optional OpenAI-compatible LLM + ASR
# DeepSeek default:
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_ASR_MODEL=

# Backward-compatible Qwen / DashScope names still work:
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_ASR_MODEL=
LLM_TIMEOUT_SECONDS=25

# 方式二：如果你不想用 DATABASE_URL，也可单独配置以下字段
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=kaogong_ai

# WeChat Pay mini program scaffold
# 当前默认 mock；拿到真实商户资料后，将 ENABLED=true 且 MOCK_MODE=false。
WECHAT_PAY_ENABLED=false
WECHAT_PAY_MOCK_MODE=true
WECHAT_PAY_SCENE=mini_program
WECHAT_PAY_APPID=wx_mock_miniprogram_appid
WECHAT_PAY_MCHID=1900000001
WECHAT_PAY_NOTIFY_URL=https://mock.example.com/payment/callback/wechat
WECHAT_PAY_API_V3_KEY=MOCK_API_V3_KEY_REPLACE_ME
WECHAT_PAY_SERIAL_NO=MOCK_SERIAL_NO_REPLACE_ME
WECHAT_PAY_PRIVATE_KEY_PATH=certs/mock_apiclient_key.pem
WECHAT_PAY_PLATFORM_CERT_PATH=certs/mock_wechatpay_platform.pem
WECHAT_PAY_API_BASE=https://api.mch.weixin.qq.com
WECHAT_PAY_REQUEST_TIMEOUT=10
