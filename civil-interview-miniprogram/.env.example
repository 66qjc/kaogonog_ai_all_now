# 通用兜底（不建议只配这一项）
VITE_API_BASE=/api

# H5 地址（开发可写 http://127.0.0.1:8050，生产通常写 /api）
VITE_API_BASE_H5=/api

# 小程序地址（必须完整 URL，不能只写 /api）
# 本机开发示例：
# VITE_API_BASE_MP_WEIXIN=http://127.0.0.1:8050
# 局域网联调示例：
# VITE_API_BASE_MP_WEIXIN=http://192.168.1.23:8050
# 线上示例（真机建议 https）：
# VITE_API_BASE_MP_WEIXIN=https://example.com/api
VITE_API_BASE_MP_WEIXIN=http://127.0.0.1:8050
VITE_WECHAT_APPID=wxa31c6e32dfa4b178

# debug | info | warn | error | silent
# 真机/生产建议 error；开发联调可用 debug。
VITE_LOG_LEVEL=debug
